POSTGRES_DB=cashpilot
POSTGRES_USER=cashpilot
POSTGRES_PASSWORD=cashpilot
POSTGRES_PORT=5433
REDIS_PORT=6380
API_PORT=8001
DJANGO_SECRET_KEY=change-me-in-production
# Inclui [::1] para quando o SO não resolve localhost para 127.0.0.1 (ex.: IPv6).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# Origens do navegador ao acessar a API no host (ajuste a porta se API_PORT mudar).
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001,http://[::1]:8001
